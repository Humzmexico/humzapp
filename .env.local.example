# ======================
# DATABASE CONFIGURATION
# ======================

# PostgreSQL connection string
# For Supabase: postgresql://[user]:[password]@[host]:[port]/[database]
# For Neon: postgresql://[user]:[password]@[host]/[database]?sslmode=require
# For Local: postgresql://postgres:password@localhost:5432/humz

DATABASE_URL="postgresql://user:password@localhost:5432/humz"

# ======================
# APPLICATION CONFIG
# ======================

# Default organization for MVP testing
# Format: org_[random-string]
NEXT_PUBLIC_DEFAULT_ORG_ID="org_test_123"

# ======================
# AUTHENTICATION (Future)
# ======================

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-key-here"

# NextAuth URL
NEXTAUTH_URL="http://localhost:3000"

# ======================
# INTEGRATIONS (Future)
# ======================

# Stripe
# STRIPE_PUBLIC_KEY=""
# STRIPE_SECRET_KEY=""

# WhatsApp Business API
# WHATSAPP_API_TOKEN=""
# WHATSAPP_PHONE_ID=""

# Invent Integration
# INVENT_API_KEY=""
# INVENT_WEBHOOK_SECRET=""

# ======================
# ENVIRONMENT
# ======================

# vercel | production | development
NODE_ENV="development"
